{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Production-grade template that deploys a Consumption Logic App together with the Azure Blob Storage and Office 365 Outlook managed API connections it depends on. The workflow definition itself is injected as a parameter (workflowDefinition) so workflow.json is never hardcoded into this file."
  },

  "parameters": {
    "logicAppName": {
      "type": "string",
      "metadata": { "description": "Name of the Consumption Logic App." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for the Logic App and its connections." }
    },
    "logicAppState": {
      "type": "string",
      "defaultValue": "Enabled",
      "allowedValues": [ "Enabled", "Disabled" ],
      "metadata": { "description": "Enabled/Disabled state of the Logic App, driven by deployment configuration." }
    },
    "workflowDefinition": {
      "type": "string",
      "metadata": { "description": "The full Logic Apps workflow definition JSON (contents of workflow.json), passed in as an override parameter by the pipeline job template." }
    },
    "storageAccountName": {
      "type": "string",
      "metadata": { "description": "Name of the Storage Account monitored by the workflow (passed to the workflow parameters)." }
    },
    "containerName": {
      "type": "string",
      "metadata": { "description": "Blob container monitored by the workflow." }
    },
    "folderPath": {
      "type": "string",
      "metadata": { "description": "Folder path inside the container to monitor." }
    },
    "emailTo": {
      "type": "string",
      "metadata": { "description": "Recipient email address for blob-notification emails." }
    },
    "workflowRecurrenceInterval": {
      "type": "int",
      "defaultValue": 5,
      "metadata": { "description": "Recurrence trigger interval, e.g. 5." }
    },
    "workflowRecurrenceFrequency": {
      "type": "string",
      "defaultValue": "Minute",
      "allowedValues": [ "Second", "Minute", "Hour", "Day", "Week", "Month" ],
      "metadata": { "description": "Recurrence trigger frequency unit." }
    }
  },

  "variables": {
    "logicApiVersion": "2019-05-01",
    "connectionApiVersion": "2018-07-01-preview",
    "azureBlobConnectionName": "azureblob",
    "office365ConnectionName": "office365",
    "azureBlobManagedApiId": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azureblob')]",
    "office365ManagedApiId": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'office365')]"
  },

  "resources": [
    {
      // Managed API connection - Azure Blob Storage
      "type": "Microsoft.Web/connections",
      "apiVersion": "[variables('connectionApiVersion')]",
      "name": "[variables('azureBlobConnectionName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[format('{0}-blob-connection', parameters('logicAppName'))]",
        "api": {
          "id": "[variables('azureBlobManagedApiId')]"
        },
        "parameterValues": {
          "accountName": "[parameters('storageAccountName')]",
          "accessKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName')), '2023-01-01').keys[0].value]"
        }
      }
    },
    {
      // Managed API connection - Office 365 Outlook (requires interactive OAuth consent post-deployment)
      "type": "Microsoft.Web/connections",
      "apiVersion": "[variables('connectionApiVersion')]",
      "name": "[variables('office365ConnectionName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[format('{0}-office365-connection', parameters('logicAppName'))]",
        "api": {
          "id": "[variables('office365ManagedApiId')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "[variables('logicApiVersion')]",
      "name": "[parameters('logicAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('azureBlobConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('office365ConnectionName'))]"
      ],
      "properties": {
        "state": "[parameters('logicAppState')]",
        "definition": "[parameters('workflowDefinition')]",
        "parameters": {
          "$connections": {
            "value": {
              "azureblob": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('azureBlobConnectionName'))]",
                "connectionName": "[variables('azureBlobConnectionName')]",
                "id": "[variables('azureBlobManagedApiId')]"
              },
              "office365": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('office365ConnectionName'))]",
                "connectionName": "[variables('office365ConnectionName')]",
                "id": "[variables('office365ManagedApiId')]"
              }
            }
          },
          "storageAccountName": {
            "value": "[parameters('storageAccountName')]"
          },
          "containerName": {
            "value": "[parameters('containerName')]"
          },
          "folderPath": {
            "value": "[parameters('folderPath')]"
          },
          "emailTo": {
            "value": "[parameters('emailTo')]"
          },
          "recurrenceInterval": {
            "value": "[parameters('workflowRecurrenceInterval')]"
          },
          "recurrenceFrequency": {
            "value": "[parameters('workflowRecurrenceFrequency')]"
          }
        }
      }
    }
  ],

  "outputs": {
    "logicAppId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('logicAppName'))]"
    },
    "logicAppName": {
      "type": "string",
      "value": "[parameters('logicAppName')]"
    },
    "office365ConnectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/connections', variables('office365ConnectionName'))]"
    }
  }
}
